{
  "expo": {
    "name": "Attendance Pro",
    "slug": "attendance-pro",
    "version": "1.0.4",
    "scheme": [
      "attendance-pro",
      "com.attendancepro.app"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A90E2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.attendancepro.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A90E2"
      },
      "package": "com.attendancepro.app"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-updates",
      "expo-font",
      "expo-notifications",
      "@react-native-google-signin/google-signin"
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "url": "https://u.expo.dev/55c4030f-c64c-41ca-aa9e-af49c013347d",
      "fallbackToCacheTimeout": 30000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "API_URL": "https://backend-theta-two-72.vercel.app/api",
      "eas": {
        "projectId": "55c4030f-c64c-41ca-aa9e-af49c013347d"
      }
    },
    "owner": "rahuladya"
  }
}
